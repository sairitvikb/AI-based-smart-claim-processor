# ----------------------------------------------------
# Smart Claims Processor - Environment Configuration
# Copy this file to .env and fill in your values
# ----------------------------------------------------

# -------- Country Profile -------------------------------------------
COUNTRY=india                        # india | us

# -------- LLM Provider -------------------------------------------
# Only need the key for the provider you pick.
LLM_PROVIDER=groq                    # groq | gemini

# Groq - free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Gemini - free key at https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=your_gemini_api_key_here

# -------- LLM Tuning (optional) -------------------------------------------
# LLM_MODEL=llama-3.1-8b-instant     # change the agent model (defaults are in configs/base.yaml)
# LLM_TEMPERATURE=0.1

# -------- API / Auth -------------------------------------------
API_SECRET_KEY=change-me-to-a-long-random-string   # JWT signing key
# API_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# -------- HITL (Human-In-The-Loop) Thresholds (optional) -------------------------------------------
# HITL_MIN_AMOUNT=10000          # Claims >= $10K require human review
# HITL_FRAUD_THRESHOLD=0.45      # Fraud score >= 0.45 triggers HITL
# HITL_LOW_CONFIDENCE=0.65       # Agent confidence < 0.65 triggers HITL

# -------- Budget Guards (optional) -------------------------------------------─
# MAX_TOKENS_PER_CLAIM=50000
# MAX_COST_PER_CLAIM=0.50
# MAX_AGENT_CALLS=25

# -------- Security (optional) -------------------------------------------
# AUDIT_LOG_PATH=./data/audit_logs/
# PII_MASKING_ENABLED=true
